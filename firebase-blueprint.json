{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with role-based access",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "User email address" },
        "role": { "type": "string", "enum": ["admin", "student"], "description": "Access level" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account registration time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Document": {
      "title": "Document",
      "description": "Exam resource document",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Document title" },
        "exam": { "type": "string", "enum": ["Mid", "Final"], "description": "Exam period" },
        "subject": { "type": "string", "description": "Subject name" },
        "unit": { "type": "string", "description": "Unit number or name" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Descriptive tags" },
        "fileUrl": { "type": "string", "description": "Firebase Storage URL" },
        "fileType": { "type": "string", "enum": ["pdf", "image"], "description": "Resource format" },
        "uploadedBy": { "type": "string", "description": "Uploader email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Upload time" },
        "views": { "type": "number", "description": "Total view count" },
        "isImportant": { "type": "boolean", "description": "Priority flag" }
      },
      "required": ["title", "exam", "subject", "unit", "fileUrl", "fileType", "uploadedBy", "createdAt", "views", "isImportant"]
    },
    "Request": {
      "title": "Request",
      "description": "Student document request",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Requested title" },
        "subject": { "type": "string", "description": "Requested subject" },
        "unit": { "type": "string", "description": "Requested unit" },
        "requestedBy": { "type": "string", "description": "Requester email" },
        "status": { "type": "string", "enum": ["pending", "fulfilled"], "description": "Request state" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Request time" }
      },
      "required": ["title", "subject", "unit", "requestedBy", "status", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "Student document submission",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Document title" },
        "subject": { "type": "string", "description": "Subject" },
        "unit": { "type": "string", "description": "Unit" },
        "fileUrl": { "type": "string", "description": "Firebase Storage URL" },
        "submittedBy": { "type": "string", "description": "Submitter email" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Submission state" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission time" }
      },
      "required": ["title", "subject", "unit", "fileUrl", "submittedBy", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "documents/{docId}": {
      "schema": "Document",
      "description": "Main document repository"
    },
    "requests/{requestId}": {
      "schema": "Request",
      "description": "User document requests"
    },
    "submissions/{submissionId}": {
      "schema": "Submission",
      "description": "Pending student submissions"
    }
  }
}
